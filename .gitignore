# ==========================================
# Standard MERN Stack .gitignore
# ==========================================

# --- Dependencies ---
node_modules/
jspm_packages/
typings/

# --- Environment Variables (CRITICAL: Never commit these) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
.env.stack8

# --- Build and Distribution ---
dist/
dist-ssr
*.local
build/
out/
.next/
.serverless/
bin/
obj/

# --- Logs and Debugging ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log
logs/
*.lcov

# --- Testing ---
coverage/
.nyc_output/
*.spec.js.snap
*.test.js.snap

# --- IDEs and Editors ---
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.classpath
.project
.settings/

# --- Operating System Files ---
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# --- Database (Local) ---
*.db
*.sqlite
data/db/
dump/

# --- Tools ---
.cache/
.eslintcache
.stylelintcache
.prettiercache
.parcel-cache
.turbo/